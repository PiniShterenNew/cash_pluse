# CashPulse — Environment Variables
# Copy to .env.local and fill in all values
# ⚠️ Never commit .env.local to git

# ─── Supabase ──────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-only. Never expose to client.

# ─── WhatsApp Cloud API (Meta) ─────────────────────────────
# From: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=              # Permanent system user token (not temp token)
WHATSAPP_PHONE_NUMBER_ID=           # e.g. 123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=       # e.g. 987654321098765
WHATSAPP_WEBHOOK_VERIFY_TOKEN=      # Arbitrary secret you choose for webhook verification

# ─── PayPlus (Israeli Payment Gateway) ─────────────────────
# From: https://payplus.co.il → Developer → API Keys
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_TERMINAL_UID=               # Your merchant terminal ID
PAYPLUS_WEBHOOK_SECRET=             # For signature verification on payment webhooks

# ─── OpenAI ────────────────────────────────────────────────
# From: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── PostHog ───────────────────────────────────────────────
# From: https://app.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to https://yourdomain.com in production
